<Window x:Class="AppMigrator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Win Apps Migrator v0.0.18"
        Width="1420"
        Height="840"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource PageBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextStrongBrush}"
        TextElement.FontFamily="Segoe UI"
        TextElement.FontSize="14">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F7FC"/>
        <SolidColorBrush x:Key="ShellBrush" Color="#EEF2F8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F7F9FD"/>
        <SolidColorBrush x:Key="SurfaceAccentBrush" Color="#EAF1FF"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#D8E0ED"/>
        <SolidColorBrush x:Key="StrokeStrongBrush" Color="#C1CEE2"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#3369FF"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#E8F0FF"/>
        <SolidColorBrush x:Key="PrimaryContainerTextBrush" Color="#2249C5"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#1A8A5A"/>
        <SolidColorBrush x:Key="SuccessContainerBrush" Color="#DCF6E7"/>
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#0E6A45"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#B56F0D"/>
        <SolidColorBrush x:Key="WarningContainerBrush" Color="#FFF1DA"/>
        <SolidColorBrush x:Key="WarningTextBrush" Color="#93580A"/>
        <SolidColorBrush x:Key="TextStrongBrush" Color="#172033"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#8B9AB1"/>

        <DropShadowEffect x:Key="ShellShadow" BlurRadius="46" ShadowDepth="0" Opacity="0.16"/>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="30" ShadowDepth="0" Opacity="0.12"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="0" Opacity="0.10"/>

        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
        </Style>

        <Style x:Key="HeroCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Effect="{StaticResource CardShadow}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.96"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.54"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="TonalButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryContainerTextBrush}"/>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource TextSoftBrush}"/>
            <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.82"/>
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSoftBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
        </Style>

        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="9"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="HeaderRoot"
                                Margin="0,0,6,0"
                                Padding="8,4"
                                CornerRadius="10"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderRoot" Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
                                <Setter TargetName="HeaderRoot" Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryContainerTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderRoot" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactTabControlStyle" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0"
                                      x:Name="HeaderPanel"
                                      Background="Transparent"
                                      Margin="0,0,0,4"
                                      IsItemsHost="True"/>
                            <ContentPresenter Grid.Row="1"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbRoot"
                                Margin="1"
                                Background="{DynamicResource StrokeStrongBrush}"
                                CornerRadius="4"
                                Opacity="0.88"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Width="7" Background="Transparent" Margin="0,2,0,2">
                            <Border Width="3"
                                    HorizontalAlignment="Right"
                                    CornerRadius="4"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    Opacity="0.8"/>
                            <Track x:Name="PART_Track" Focusable="False" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource ModernScrollBarRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource ModernScrollBarRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="8"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter TargetName="Root" Property="Width" Value="Auto"/>
                                <Setter TargetName="Root" Property="Height" Value="8"/>
                                <Setter TargetName="Root" Property="Margin" Value="2,0,2,0"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBarStyle}"/>

        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="Root" SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <Grid Margin="1" ClipToBounds="True">
                                <Border x:Name="PART_Track" Background="Transparent" CornerRadius="5"/>>
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#4B7BFF" Offset="0"/>
                                            <GradientStop Color="#2E5EF2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Width" Value="120"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppCardItemStyle" TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Border Margin="14"
                Background="{DynamicResource ShellBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="34"
                Effect="{StaticResource ShellShadow}"
                SnapsToDevicePixels="True">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <Border Style="{StaticResource HeroCardStyle}" Margin="0,0,0,4">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="148"
                                        Height="148"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource StrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="4"
                                        HorizontalAlignment="Center">
                                    <Image Source="Assets/WinAppsMigrator_logo.png"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <TextBlock Text="Win Apps Migrator"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextStrongBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="VersionTextBlock"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource PrimaryContainerTextBrush}"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="AuthorTextBlock"
                                           Visibility="Collapsed"
                                           Height="0"
                                           Opacity="0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Overview" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="Quick view of what is detected and what will move cleanly."
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"/>
                                <Border Margin="0,10,0,0"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource StrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="12">
                                    <TextBlock x:Name="SummaryTextBlock"
                                               Foreground="{DynamicResource TextStrongBrush}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Actions" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="Run discovery, create a backup ZIP, or restore to another system."
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <Button x:Name="ScanButton"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="ScanButton_Click"
                                        Margin="0,10,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Scan installed apps" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BackupButton"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="BackupButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Back up selected" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="RestoreButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="RestoreButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Restore" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Restore backup ZIP" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Selection" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="Filter the catalog, then keep only the apps you want to migrate."
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="SelectSupportedButton"
                                            Grid.Column="0"
                                            Style="{StaticResource TonalButtonStyle}"
                                            Click="SelectSupportedButton_Click"
                                            Margin="0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="Select supported"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ClearSelectionButton"
                                            Grid.Column="2"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ClearSelectionButton_Click"
                                            Margin="0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CloseCircleOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="Clear"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <CheckBox x:Name="SupportedOnlyCheckBox"
                                          Style="{StaticResource ModernCheckBoxStyle}"
                                          Checked="FilterChanged"
                                          Unchecked="FilterChanged">
                                    Show supported only
                                </CheckBox>

                                <CheckBox x:Name="UseWingetCheckBox"
                                          IsChecked="True"
                                          Style="{StaticResource ModernCheckBoxStyle}">
                                    Install missing apps with WinGet during restore
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Resources" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Text="Check the latest release and jump to the project page."/>
                                <Button x:Name="UpdateButton"
                                        Style="{StaticResource TonalButtonStyle}"
                                        Click="UpdateButton_Click"
                                        Margin="0,10,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Update" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Check latest build"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ProjectButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ProjectButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="OpenInNew" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open releases page"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SurfaceCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Library" FontSize="17" FontWeight="SemiBold"/>
                                </StackPanel>

                                <Button x:Name="ThemeToggleButton"
                                        Grid.Column="1"
                                        Width="38"
                                        Height="38"
                                        Margin="12,0,0,0"
                                        Background="{DynamicResource SurfaceAccentBrush}"
                                        BorderBrush="{DynamicResource StrokeStrongBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="ThemeToggleButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ToggleRoot"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="14"
                                                    Effect="{StaticResource CardShadow}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ToggleRoot" Property="Opacity" Value="0.95"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ToggleRoot" Property="Opacity" Value="0.88"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ToggleRoot" Property="Opacity" Value="0.54"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <materialDesign:PackIcon x:Name="ThemeToggleIcon"
                                                             Kind="WeatherNight"
                                                             Width="20"
                                                             Height="20"
                                                             Foreground="{DynamicResource PrimaryContainerTextBrush}"/>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="2">
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock Text="Search"
                                               Margin="0,0,0,5"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"/>
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource StrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,0"
                                        MinHeight="34"
                                        Width="260"
                                        MaxWidth="420"
                                        HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Magnify"
                                                                 Width="17"
                                                                 Height="17"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource TextSoftBrush}"/>
                                        <TextBox Grid.Column="1"
                                                 x:Name="SearchTextBox"
                                                 Style="{StaticResource SearchTextBoxStyle}"
                                                 TextChanged="SearchTextBox_TextChanged"
                                                 materialDesign:HintAssist.Hint="Search apps, rules, or package IDs"/>
                                    </Grid>
                                </Border>
                                </StackPanel>

                                <Button x:Name="UpdateButtonTop"
                                        Visibility="Collapsed"
                                        Width="0"
                                        Height="0"
                                        Click="UpdateButton_Click"
                                        Margin="0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource SurfaceCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="148"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="182"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="ProgressStageTextBlock"
                                               Text="Ready"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ProgressMessageTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="Close selected apps before backup or restore for best results."/>
                                </StackPanel>

                                <Border Grid.Column="2" Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Current app"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="13"/>
                                        <TextBlock x:Name="CurrentAppTextBlock"
                                                   Margin="0,6,0,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="—"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Transfer"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="13"/>
                                        <TextBlock x:Name="TransferStatsTextBlock"
                                                   Margin="0,6,0,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="0 MB / 0 MB"/>
                                        <TextBlock x:Name="EtaTextBlock"
                                                   Margin="0,6,0,0"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Text="ETA: --"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ProgressBar Grid.Row="2"
                                         x:Name="OperationProgressBar"
                                         Style="{StaticResource ModernProgressBarStyle}"
                                         Minimum="0"
                                         Maximum="100"
                                         Margin="0,2,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource SurfaceCardStyle}">
                        <TabControl Style="{StaticResource CompactTabControlStyle}"
                                    Background="Transparent"
                                    BorderThickness="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem" BasedOn="{StaticResource TabHeaderStyle}"/>
                            </TabControl.Resources>

                            <TabItem Header="Apps">
                                <Grid Margin="0,6,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource StrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="5"
                                            Margin="0,0,0,2">
                                        <StackPanel>
                                            <TextBlock Text="App selection"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       FontSize="11.5"
                                                       Text="Pick the apps you want to migrate."/>
                                        </StackPanel>
                                    </Border>

                                    <ListBox Grid.Row="1"
                                             x:Name="AppsDataGrid"
                                             Margin="0,0,0,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource AppCardItemStyle}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="True"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel">
                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                                        </ListBox.Resources>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="CardRoot"
                                                        Background="{DynamicResource SurfaceRaisedBrush}"
                                                        BorderBrush="{DynamicResource StrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="6"
                                                        Effect="{StaticResource CardShadow}"
                                                        PreviewMouseLeftButtonUp="AppCard_PreviewMouseLeftButtonUp">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="24"
                                                                Height="24"
                                                                CornerRadius="10"
                                                                Background="{DynamicResource SurfaceAccentBrush}"
                                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding BadgeText}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource PrimaryBrush}"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                                            <DockPanel LastChildFill="True">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="12.8"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </DockPanel>
                                                            <TextBlock Margin="0,1,0,0"
                                                                       Text="{Binding Publisher}"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       FontSize="10.8"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <WrapPanel Margin="0,3,0,0">
                                                                <Border>
                                                                    <Border.Style>
                                                                        <Style TargetType="Border" BasedOn="{StaticResource ChipBorderStyle}">
                                                                            <Setter Property="Background" Value="{DynamicResource WarningContainerBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                                    <Setter Property="Background" Value="{DynamicResource SuccessContainerBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock FontWeight="SemiBold" FontSize="10.2">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="Metadata"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                                        <Setter Property="Text" Value="Supported"/>
                                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>

                                                                <Border Style="{StaticResource ChipBorderStyle}">
                                                                    <TextBlock Text="{Binding Category}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="10.2"
                                                                               Foreground="{DynamicResource TextStrongBrush}"/>
                                                                </Border>

                                                                <Border Background="{DynamicResource PrimaryContainerBrush}"
                                                                        Style="{StaticResource ChipBorderStyle}">
                                                                    <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}"
                                                                               Foreground="{DynamicResource PrimaryContainerTextBrush}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="10.2"/>
                                                                </Border>

                                                                <Border Background="{DynamicResource SurfaceAccentBrush}"
                                                                        Style="{StaticResource ChipBorderStyle}">
                                                                    <TextBlock Text="{Binding RestoreStrategy}"
                                                                               Foreground="{DynamicResource TextStrongBrush}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="10.2"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="130"/>
                                                                </Border>
                                                            </WrapPanel>
                                                        </StackPanel>

                                                        <Border x:Name="SelectionBadge"
                                                                Grid.Column="2"
                                                                Background="{DynamicResource PrimaryContainerBrush}"
                                                                BorderBrush="{DynamicResource StrokeStrongBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="5,3"
                                                                Visibility="Collapsed"
                                                                VerticalAlignment="Top">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="CheckCircle" Width="13" Height="13" Foreground="{DynamicResource PrimaryContainerTextBrush}"/>
                                                                <TextBlock Margin="6,0,0,0"
                                                                           Text="Included"
                                                                           FontSize="11.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryContainerTextBrush}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
                                                        <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
                                                        <Setter TargetName="SelectionBadge" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Activity">
                                <Grid Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource StrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Live activity"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="Watch scan results, backup progress, restore actions, WinGet installs, registry work, and verification checks in one place."/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource SurfaceRaisedBrush}"
                                            BorderBrush="{DynamicResource StrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            Padding="10"
                                            Effect="{StaticResource CardShadow}">
                                        <TextBox x:Name="LogTextBox"
                                                 Margin="0,0,4,0"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextStrongBrush}"
                                                 BorderThickness="0"
                                                 Padding="12"
                                                 FontFamily="Cascadia Code, Consolas, Segoe UI Mono"
                                                 FontSize="13"/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
