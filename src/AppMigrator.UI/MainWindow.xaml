<Window x:Class="AppMigrator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Win Apps Migrator V0.0.7"
        Height="930"
        Width="1560"
        MinHeight="840"
        MinWidth="1360"
        Background="#F3F5F9"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F3F5F9"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedSurfaceBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#E6EBF2"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F6BFF"/>
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#EEF4FF"/>
        <SolidColorBrush x:Key="TextStrongBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#667085"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#117A4A"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#B45309"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="0" Opacity="0.08"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}"/>
            <Setter Property="Background" Value="#EEF2F7"/>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D7DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppCardItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="#F8FAFD" BorderBrush="#E7ECF2" BorderThickness="1" CornerRadius="14,14,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#D9E5FF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FBFDFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" Margin="0,0,0,14" IsItemsHost="True" Background="Transparent"/>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="80" Height="80" CornerRadius="24" Background="#0F172A" VerticalAlignment="Top">
                            <Viewbox Margin="12">
                                <Canvas Width="54" Height="54">
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Fill="#66B0FF" Canvas.Left="2" Canvas.Top="2"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Fill="#2F7DFF" Canvas.Left="28" Canvas.Top="2"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Fill="#1A5DFF" Canvas.Left="2" Canvas.Top="28"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Fill="#B7D2FF" Canvas.Left="31" Canvas.Top="23" RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform>
                                            <RotateTransform Angle="18"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="8,4,0,0">
                            <TextBlock Text="Win Apps Migrator" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" TextWrapping="Wrap"/>
                            <TextBlock Name="VersionTextBlock" Margin="0,8,0,0" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                            <TextBlock Name="AuthorTextBlock" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Overview" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}"/>
                        <TextBlock Name="SummaryTextBlock" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Actions" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}"/>
                        <Button Name="ScanButton" Margin="0,14,0,10" Style="{StaticResource PrimaryButtonStyle}" Click="ScanButton_Click">Scan installed apps</Button>
                        <Button Name="BackupButton" Style="{StaticResource PrimaryButtonStyle}" Click="BackupButton_Click">Back up selected</Button>
                        <Button Name="RestoreButton" Style="{StaticResource SecondaryButtonStyle}" Click="RestoreButton_Click">Restore backup ZIP</Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Selection" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}"/>
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Name="SelectSupportedButton" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Click="SelectSupportedButton_Click">Select supported</Button>
                            <Button Name="ClearSelectionButton" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Click="ClearSelectionButton_Click">Clear</Button>
                        </Grid>
                        <CheckBox Name="SupportedOnlyCheckBox" Margin="0,10,0,0" Checked="FilterChanged" Unchecked="FilterChanged" Content="Show supported only"/>
                        <CheckBox Name="UseWingetCheckBox" Margin="0,10,0,0" IsChecked="True" Content="Install missing apps with WinGet during restore"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Links" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}"/>
                        <Button Name="UpdateButton" Margin="0,14,0,10" Style="{StaticResource SecondaryButtonStyle}" Click="UpdateButton_Click">Check updates</Button>
                        <Button Name="ProjectButton" Style="{StaticResource SecondaryButtonStyle}" Click="ProjectButton_Click">Open project page</Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" CornerRadius="22" Background="#0F172A" Padding="16" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Tips" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#D0D5DD"
                                   Text="Close browsers, sync clients, editors, and Adobe apps before backup or restore. Click an app card anywhere to select it."/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Library" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}"/>
                        <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" Text="Review detected apps, search the catalog, and choose what to migrate."/>
                    </StackPanel>
                    <TextBox Grid.Column="1" Name="SearchTextBox" Style="{StaticResource RoundedTextBoxStyle}" Margin="18,0,16,0" TextChanged="SearchTextBox_TextChanged"/>
                    <Button Grid.Column="2" Name="UpdateButtonTop" Style="{StaticResource SecondaryButtonStyle}" Height="46" Margin="0" Click="UpdateButton_Click">Search updates live</Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="210"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Name="ProgressStageTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" Text="Ready"/>
                        <TextBlock Name="ProgressMessageTextBlock" Margin="0,8,0,12" Foreground="{StaticResource TextMutedBrush}" Text="Close selected apps before backup or restore for best results."/>
                        <ProgressBar Name="OperationProgressBar" Height="14" Minimum="0" Maximum="100" Value="0" Foreground="#1F6BFF" Background="#E8EEF8" BorderThickness="0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Margin="20,0,16,0" Background="{StaticResource MutedSurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Current app" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Name="CurrentAppTextBlock" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" Text="—" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource MutedSurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Transfer" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Name="TransferStatsTextBlock" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" Text="0 MB / 0 MB"/>
                            <TextBlock Name="EtaTextBlock" Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" Text="ETA: --"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,18,0,0">
                <TabControl Style="{StaticResource ModernTabControlStyle}">
                    <TabControl.Resources>
                        <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItemStyle}"/>
                    </TabControl.Resources>
                    <TabItem Header="Apps">
                        <Grid Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="18" Background="#F8FAFD" BorderBrush="#E7ECF2" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Click anywhere on a card to include or remove it. Each card shows support status, confidence, restore method, and install details." Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Border Grid.Column="1" Background="#EEF4FF" CornerRadius="14" Padding="12,8" Margin="14,0,0,0">
                                        <TextBlock Foreground="#3359B8" FontWeight="SemiBold" Text="Card click enabled"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                     Name="AppsDataGrid"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     HorizontalContentAlignment="Stretch"
                                     ItemContainerStyle="{StaticResource AppCardItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="24" Padding="18">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#E7ECF2"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#F8FBFF"/>
                                                            <Setter Property="BorderBrush" Value="#8BB4FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid PreviewMouseLeftButtonUp="AppCard_PreviewMouseLeftButtonUp">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="250"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <Grid Width="82" Height="82" HorizontalAlignment="Left">
                                                        <Border CornerRadius="24" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#EAF2FF"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                            <Setter Property="Background" Value="#DFF7EA"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding BadgeText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#245BC7"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                                <Setter Property="Foreground" Value="#117A4A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0" Background="#1F6BFF" BorderBrush="White" BorderThickness="3">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="✓" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>

                                                    <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" FontSize="12">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Click card to include"/>
                                                                <Setter Property="Foreground" Value="#667085"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Text" Value="Included in job"/>
                                                                        <Setter Property="Foreground" Value="#117A4A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="18,0,18,0">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="21" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,5,0,0" Text="{Binding Publisher}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap"/>

                                                    <WrapPanel Margin="0,14,0,0">
                                                        <Border CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#FFF7ED"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                            <Setter Property="Background" Value="#E8FFF1"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="Metadata only"/>
                                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                                <Setter Property="Text" Value="Supported"/>
                                                                                <Setter Property="Foreground" Value="#117A4A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <Border Background="#F2F4F7" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                            <TextBlock Text="{Binding Category}" FontWeight="SemiBold" Foreground="#344054"/>
                                                        </Border>

                                                        <Border Background="#EEF4FF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                            <TextBlock Text="{Binding Confidence, StringFormat=Confidence {0:P0}}" FontWeight="SemiBold" Foreground="#3359B8"/>
                                                        </Border>

                                                        <Border Background="#F9F5FF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                            <TextBlock Text="{Binding RestoreStrategy}" FontWeight="SemiBold" Foreground="#6941C6"/>
                                                        </Border>
                                                    </WrapPanel>

                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                                        <Run Text="Version: "/>
                                                        <Run Text="{Binding Version}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                                        <Run Text="Install location: "/>
                                                        <Run Text="{Binding InstallLocation}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,8,0,0" Foreground="#475467" TextWrapping="Wrap" Text="{Binding Notes}"/>
                                                </StackPanel>

                                                <Border Grid.Column="2" CornerRadius="18" Background="#FBFCFE" BorderBrush="#E7ECF2" BorderThickness="1" Padding="14">
                                                    <StackPanel>
                                                        <TextBlock Text="Quick view" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}"/>
                                                        <TextBlock Margin="0,12,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                                            <Run Text="Rule: "/>
                                                            <Run Text="{Binding RuleId}"/>
                                                        </TextBlock>
                                                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                                            <Run Text="Publisher: "/>
                                                            <Run Text="{Binding Publisher}"/>
                                                        </TextBlock>
                                                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                                            <Run Text="Package ID: "/>
                                                            <Run Text="{Binding WingetId}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Activity">
                        <Grid Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="18" Background="#F8FAFD" BorderBrush="#E7ECF2" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Review the live job log for backup, restore, WinGet, and registry activity."/>
                            </Border>
                            <TextBox Grid.Row="1" Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#FBFCFE" BorderBrush="#E7ECF2" BorderThickness="1" Padding="14" FontFamily="Consolas" FontSize="13"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
