<Window x:Class="AppMigrator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Win Apps Migrator V0.0.10"
        Height="960"
        Width="1600"
        MinHeight="860"
        MinWidth="1420"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource PageBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextStrongBrush}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="pack://application:,,,/MaterialDesignThemes.Wpf;component/Resources/Roboto/#Roboto"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F6FB"/>
        <SolidColorBrush x:Key="ShellBrush" Color="#EDF2FA"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F7F9FE"/>
        <SolidColorBrush x:Key="SurfacePopBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TonalBrush" Color="#E8EEFF"/>
        <SolidColorBrush x:Key="TonalStrongBrush" Color="#D9E6FF"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#D8DFEC"/>
        <SolidColorBrush x:Key="StrokeStrongBrush" Color="#C5D1E2"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#3F66F1"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#E4EBFF"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#E7F3FF"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#147D52"/>
        <SolidColorBrush x:Key="SuccessContainerBrush" Color="#DCF7EA"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#B96B00"/>
        <SolidColorBrush x:Key="WarningContainerBrush" Color="#FFF1DA"/>
        <SolidColorBrush x:Key="TextStrongBrush" Color="#162033"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#91A0B5"/>

        <DropShadowEffect x:Key="ShellShadow" BlurRadius="36" ShadowDepth="0" Opacity="0.14"/>
        <DropShadowEffect x:Key="SectionShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.12"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="0" Opacity="0.10"/>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect" Value="{StaticResource SectionShadow}"/>
        </Style>

        <Style x:Key="SidebarCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Effect="{StaticResource CardShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="TonalButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ThemeToggleStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Width="64"
                                Height="48"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppCardItemStyle" TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Border Margin="16" Background="{DynamicResource ShellBrush}" CornerRadius="34" Effect="{StaticResource ShellShadow}">
            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SidebarCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="72" Height="72" CornerRadius="22" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1">
                                <Viewbox Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="38" Height="38">
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource PrimaryBrush}" RadiusX="4" RadiusY="4" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                        <Rectangle Width="16" Height="16" Fill="#74A7FF" RadiusX="4" RadiusY="4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                        <Rectangle Width="16" Height="16" Fill="#2E6BFF" RadiusX="4" RadiusY="4" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                        <Rectangle Width="16" Height="16" Fill="#AAB9DB" RadiusX="4" RadiusY="4" HorizontalAlignment="Right" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <RotateTransform Angle="18"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Grid>
                                </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Win Apps&#x0a;Migrator" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextStrongBrush}"/>
                                <TextBlock x:Name="VersionTextBlock" Margin="0,12,0,0" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AuthorTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource SidebarCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Overview" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SummaryTextBlock" Margin="0,16,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource SidebarCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Actions" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <Button x:Name="ScanButton" Style="{StaticResource PrimaryButtonStyle}" Click="ScanButton_Click">Scan installed apps</Button>
                            <Button x:Name="BackupButton" Style="{StaticResource PrimaryButtonStyle}" Click="BackupButton_Click">Back up selected</Button>
                            <Button x:Name="RestoreButton" Style="{StaticResource SecondaryButtonStyle}" Click="RestoreButton_Click">Restore backup ZIP</Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="6" Style="{StaticResource SidebarCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Selection" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="SelectSupportedButton" Grid.Column="0" Style="{StaticResource TonalButtonStyle}" Click="SelectSupportedButton_Click">Select supported</Button>
                                <Button x:Name="ClearSelectionButton" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Click="ClearSelectionButton_Click">Clear</Button>
                            </Grid>
                            <CheckBox x:Name="SupportedOnlyCheckBox" Style="{StaticResource ModernCheckBoxStyle}" Checked="FilterChanged" Unchecked="FilterChanged">Show supported only</CheckBox>
                            <CheckBox x:Name="UseWingetCheckBox" IsChecked="True" Style="{StaticResource ModernCheckBoxStyle}">Install missing apps with WinGet during restore</CheckBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="8" Style="{StaticResource SidebarCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Appearance" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextMutedBrush}" Text="Choose light or dark mode."/>
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="LightThemeRadio" Grid.Column="0" Style="{StaticResource ThemeToggleStyle}" Checked="ThemeLightRadio_Checked">
                                    <materialDesign:PackIcon Kind="WeatherSunny" Width="22" Height="22" Foreground="{DynamicResource TextStrongBrush}"/>
                                </RadioButton>
                                <RadioButton x:Name="DarkThemeRadio" Grid.Column="2" Style="{StaticResource ThemeToggleStyle}" Checked="ThemeDarkRadio_Checked">
                                    <materialDesign:PackIcon Kind="WeatherNight" Width="22" Height="22" Foreground="{DynamicResource TextStrongBrush}"/>
                                </RadioButton>
                                <StackPanel Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Theme toggle" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" Text="Sun = Light, Moon = Dark"/>
                                </StackPanel>
                            </Grid>
                            <Button x:Name="UpdateButton" Margin="0,18,0,0" Style="{StaticResource TonalButtonStyle}" Click="UpdateButton_Click">Check latest build</Button>
                            <Button x:Name="ProjectButton" Style="{StaticResource SecondaryButtonStyle}" Click="ProjectButton_Click">Open releases page</Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="340"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Library" FontSize="24" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" Text="Review detected apps, search the catalog, and choose what to migrate."/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="12,0" Margin="0,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource TextSoftBrush}"/>
                                    <TextBox Grid.Column="1" x:Name="SearchTextBox" Style="{StaticResource SearchTextBoxStyle}" TextChanged="SearchTextBox_TextChanged" materialDesign:HintAssist.Hint="Search apps, publishers, categories, or rules"/>
                                </Grid>
                            </Border>
                            <Button Grid.Column="3" x:Name="UpdateButtonTop" Style="{StaticResource TonalButtonStyle}" Margin="0" Click="UpdateButton_Click">Check latest build</Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="ProgressStageTextBlock" Text="Ready" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ProgressMessageTextBlock" Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" Text="Close selected apps before backup or restore for best results." TextWrapping="Wrap"/>
                                <Border Margin="0,18,0,0" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="4">
                                    <ProgressBar x:Name="OperationProgressBar" Height="16" Minimum="0" Maximum="100" Background="Transparent" Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                            <Border Grid.Column="2" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Current app" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock x:Name="CurrentAppTextBlock" Margin="0,10,0,0" FontSize="20" FontWeight="SemiBold" Text="—" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Transfer" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TransferStatsTextBlock" Margin="0,10,0,0" FontSize="18" FontWeight="SemiBold" Text="0 MB / 0 MB"/>
                                    <TextBlock x:Name="EtaTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource TextMutedBrush}" Text="ETA: --" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabItem Header="Apps">
                                <Grid Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,16">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="App selection" FontWeight="SemiBold"/>
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" Text="Click any card to include or remove it. Support state, confidence, restore method, and install details stay visible on each item." TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Border DockPanel.Dock="Right" Background="{DynamicResource PrimaryContainerBrush}" CornerRadius="999" Padding="14,8" Margin="18,0,0,0">
                                                <TextBlock Text="Card click enabled" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                        </DockPanel>
                                    </Border>

                                    <ListBox Grid.Row="1" x:Name="AppsDataGrid" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ItemContainerStyle="{StaticResource AppCardItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="CardRoot"
                                                        Background="{DynamicResource SurfacePopBrush}"
                                                        BorderBrush="{DynamicResource StrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="28"
                                                        Padding="22"
                                                        Effect="{StaticResource CardShadow}"
                                                        PreviewMouseLeftButtonUp="AppCard_PreviewMouseLeftButtonUp">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="300"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Grid>
                                                            <Border Width="86" Height="86" Background="{DynamicResource PrimaryContainerBrush}" CornerRadius="28" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding BadgeText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                                            </Border>
                                                            <Border x:Name="SelectionBadge" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top" Background="{DynamicResource PrimaryBrush}" Width="36" Height="36" CornerRadius="18" BorderBrush="{DynamicResource SurfacePopBrush}" BorderThickness="3">
                                                                <TextBlock Text="✓" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                        </Grid>

                                                        <StackPanel Grid.Column="1" Margin="22,0,18,0">
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="21" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                            <TextBlock Margin="0,5,0,0" Text="{Binding Publisher}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                            <WrapPanel Margin="0,14,0,0">
                                                                <Border CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="{DynamicResource WarningContainerBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                                    <Setter Property="Background" Value="{DynamicResource SuccessContainerBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock FontWeight="SemiBold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="Metadata only"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Supported}" Value="True">
                                                                                        <Setter Property="Text" Value="Supported"/>
                                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                                    <TextBlock Text="{Binding Category}" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Border Background="{DynamicResource PrimaryContainerBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                                    <TextBlock Text="{Binding Confidence, StringFormat=Confidence {0:P0}}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Border Background="{DynamicResource SecondaryContainerBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                                    <TextBlock Text="{Binding RestoreStrategy}" Foreground="{DynamicResource TextStrongBrush}" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </WrapPanel>
                                                            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap">
                                                                <Run Text="Version: "/><Run Text="{Binding Version}"/>
                                                            </TextBlock>
                                                            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap">
                                                                <Run Text="Install location: "/><Run Text="{Binding InstallLocation}"/>
                                                            </TextBlock>
                                                            <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextMutedBrush}" Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <Border Grid.Column="2" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="18">
                                                            <StackPanel>
                                                                <TextBlock Text="Quick view" FontWeight="SemiBold"/>
                                                                <TextBlock Margin="0,14,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"><Run Text="Rule: "/><Run Text="{Binding RuleId}"/></TextBlock>
                                                                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"><Run Text="Publisher: "/><Run Text="{Binding Publisher}"/></TextBlock>
                                                                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"><Run Text="Package ID: "/><Run Text="{Binding WingetId}"/></TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource TonalBrush}"/>
                                                        <Setter TargetName="SelectionBadge" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Activity">
                                <Grid Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,16">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" Text="Live output for scanning, backup, restore, WinGet installs, registry work, and verification checks."/>
                                    </Border>
                                    <Border Grid.Row="1" Background="{DynamicResource SurfacePopBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="10" Effect="{StaticResource CardShadow}">
                                        <TextBox x:Name="LogTextBox"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextStrongBrush}"
                                                 BorderThickness="0"
                                                 Padding="12"
                                                 FontFamily="Consolas"
                                                 FontSize="13"/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
