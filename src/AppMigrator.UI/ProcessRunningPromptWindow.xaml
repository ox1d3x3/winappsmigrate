<Window x:Class="AppMigrator.UI.ProcessRunningPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Close running app"
        Width="720"
        SizeToContent="Height"
        MinWidth="720"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6FB"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">
    <Window.Resources>
        <DropShadowEffect x:Key="PromptShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.12"/>
        <Style x:Key="PromptPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E6BFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Effect="{StaticResource PromptShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.94"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PromptSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PromptPrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#101828"/>
            <Setter Property="Background" Value="#EEF3FB"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border x:Name="ShellBorder" CornerRadius="28" Background="White" BorderBrush="#DFE6F0" BorderThickness="1" Padding="24" Effect="{StaticResource PromptShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="AlertBadge" Width="64" Height="64" CornerRadius="20" Background="#FFF7ED">
                        <TextBlock Text="!" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="#C2410C"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock x:Name="TitleTextBlock" FontSize="28" FontWeight="SemiBold" Foreground="#101828" TextWrapping="Wrap"/>
                        <TextBlock x:Name="SubtitleTextBlock" Margin="0,8,0,0" Foreground="#667085" TextWrapping="Wrap" Text="Close the app, then choose how to continue. If the timer ends first, this app will be skipped automatically."/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ProcessesBorder" Grid.Row="1" Margin="0,22,0,0" CornerRadius="20" Background="#FBFCFE" BorderBrush="#DFE6F0" BorderThickness="1" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="ProcessesHeaderTextBlock" FontWeight="SemiBold" Foreground="#101828" Text="Detected running processes"/>
                        <TextBlock x:Name="MessageTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#475467"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TimerBorder" Grid.Column="0" CornerRadius="20" Background="#EEF4FF" Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="TimerHeaderTextBlock" Foreground="#3359B8" FontWeight="SemiBold" Text="Timer"/>
                            <TextBlock x:Name="CountdownTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Foreground="#1D4ED8" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" CornerRadius="20" Background="#F8FAFD" BorderBrush="#DFE6F0" BorderThickness="1" Padding="14">
                        <TextBlock x:Name="HelpTextBlock" Foreground="#475467" TextWrapping="Wrap" Text="Best results come from closing browsers, sync clients, editors, and Adobe apps before backup or restore."/>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Margin="0,18,0,0" CornerRadius="20" Background="#F8FAFD" BorderBrush="#DFE6F0" BorderThickness="1" Padding="14">
                    <TextBlock x:Name="PromptNoteTextBlock" Foreground="#667085" TextWrapping="Wrap" Text="Choose Continue after close when the app has been closed. Choose Skip app to move to the next item, or Cancel job to stop the current operation."/>
                </Border>

                <Grid Grid.Row="4" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#F8FAFD" BorderBrush="#DFE6F0" BorderThickness="1" CornerRadius="18" Padding="14">
                        <TextBlock x:Name="ActionHintTextBlock" Foreground="#667085" Text="Buttons stay visible here. Pick what to do next."/>
                    </Border>
                    <Button x:Name="RetryButton" Grid.Column="1" Style="{StaticResource PromptPrimaryButtonStyle}" Click="RetryButton_Click">Continue after close</Button>
                    <Button x:Name="SkipButton" Grid.Column="3" Margin="0" Style="{StaticResource PromptSecondaryButtonStyle}" Click="SkipButton_Click">Skip app</Button>
                    <Button x:Name="CancelButtonEx" Grid.Column="5" Margin="0" Style="{StaticResource PromptSecondaryButtonStyle}" Click="CancelButtonEx_Click">Cancel job</Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
