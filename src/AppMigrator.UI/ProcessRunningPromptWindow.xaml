<Window x:Class="AppMigrator.UI.ProcessRunningPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Close running app"
        Width="760"
        Height="520"
        MinWidth="660"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">
    <Window.Resources>
        <DropShadowEffect x:Key="PromptShadow" BlurRadius="28" ShadowDepth="0" Opacity="0.14"/>

        <Style x:Key="PromptPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3B63F2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Effect="{StaticResource PromptShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.95"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PromptSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PromptPrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#162033"/>
            <Setter Property="Background" Value="#F6F8FC"/>
            <Setter Property="BorderBrush" Value="#D9E1F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PromptTonalButtonStyle" TargetType="Button" BasedOn="{StaticResource PromptPrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#2746C7"/>
            <Setter Property="Background" Value="#E7EDFF"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border x:Name="ShellBorder"
                Background="White"
                BorderBrush="#D9E1F0"
                BorderThickness="1"
                CornerRadius="28"
                Padding="24"
                Effect="{StaticResource PromptShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="AlertBadge" Width="72" Height="72" CornerRadius="22" Background="#FFF4E6" BorderBrush="#F1E2C9" BorderThickness="1">
                        <materialDesign:PackIcon Kind="AlertOutline" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#AF6C0F"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleTextBlock" FontSize="28" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#162033"/>
                        <TextBlock x:Name="SubtitleTextBlock" Margin="0,8,0,0" Foreground="#64748B" TextWrapping="Wrap" Text="Close the app, then continue. If the timer finishes first, this app will be skipped automatically."/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ProcessesBorder" Background="#F6F8FC" BorderBrush="#D9E1F0" BorderThickness="1" CornerRadius="22" Padding="18">
                        <StackPanel>
                            <TextBlock x:Name="ProcessesHeaderTextBlock" Text="Detected running processes" FontWeight="SemiBold" Foreground="#162033"/>
                            <TextBlock x:Name="MessageTextBlock" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#5A6A82"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" x:Name="TimerBorder" Background="#EEF2FF" BorderBrush="#D9E1F0" BorderThickness="1" CornerRadius="22" Padding="18">
                        <StackPanel>
                            <TextBlock x:Name="TimerHeaderTextBlock" Text="Timer" FontWeight="SemiBold" Foreground="#2746C7"/>
                            <TextBlock x:Name="CountdownTextBlock" Margin="0,12,0,0" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#2746C7"/>
                            <TextBlock x:Name="HelpTextBlock" Margin="0,14,0,0" Foreground="#64748B" TextWrapping="Wrap" Text="Close browsers, sync clients, editors, and Adobe apps before backup or restore."/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="4" x:Name="PromptNoteBorder" Background="#F9FBFF" BorderBrush="#D9E1F0" BorderThickness="1" CornerRadius="22" Padding="18">
                    <StackPanel>
                        <TextBlock x:Name="PromptNoteTextBlock" Foreground="#64748B" TextWrapping="Wrap" Text="Continue after close when the process is gone. Skip app moves on without this app. Cancel job stops the current backup or restore."/>
                        <TextBlock x:Name="ActionHintTextBlock" Margin="0,12,0,0" Foreground="#93A2BA" TextWrapping="Wrap" Text="Buttons stay visible below so you do not have to wait for the timer."/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CancelButtonEx" Grid.Column="0" Style="{StaticResource PromptSecondaryButtonStyle}" Click="CancelButtonEx_Click">Cancel job</Button>
                    <Button x:Name="SkipButton" Grid.Column="4" Style="{StaticResource PromptTonalButtonStyle}" Click="SkipButton_Click">Skip app</Button>
                    <Button x:Name="RetryButton" Grid.Column="6" Style="{StaticResource PromptPrimaryButtonStyle}" Click="RetryButton_Click">Continue after close</Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
