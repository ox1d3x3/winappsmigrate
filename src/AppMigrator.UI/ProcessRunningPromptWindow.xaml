<Window x:Class="AppMigrator.UI.ProcessRunningPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Close running app"
        Height="380"
        Width="600"
        MinHeight="380"
        MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F5F9"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Border CornerRadius="28" Background="White" BorderBrush="#E6EBF2" BorderThickness="1" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="64" Height="64" CornerRadius="20" Background="#FFF7ED">
                        <TextBlock Text="!" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="#C2410C"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock Name="TitleTextBlock" FontSize="27" FontWeight="SemiBold" Foreground="#0F172A" TextWrapping="Wrap"/>
                        <TextBlock Margin="0,8,0,0" Foreground="#667085" Text="Close the app, then continue. If nothing is pressed before the timer ends, this app will be skipped automatically." TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0,22,0,0" CornerRadius="18" Background="#FBFCFE" BorderBrush="#E6EBF2" BorderThickness="1" Padding="16">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#0F172A" Text="Detected running processes"/>
                        <TextBlock Name="MessageTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#475467"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Margin="0,16,0,0" CornerRadius="18" Background="#EEF4FF" Padding="14">
                    <StackPanel>
                        <TextBlock Foreground="#3359B8" FontWeight="SemiBold" Text="Timer"/>
                        <TextBlock Name="CountdownTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Margin="0,16,0,0" CornerRadius="18" Background="#F8FAFC" BorderBrush="#E6EBF2" BorderThickness="1" Padding="14">
                    <TextBlock Foreground="#475467" TextWrapping="Wrap"
                               Text="Best results come from closing browsers, sync clients, editors, and Adobe apps before backup or restore. If the app stays open, files may be skipped or copied in an inconsistent state."/>
                </Border>

                <StackPanel Grid.Row="5" Margin="0,24,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="RetryButton" Width="154" Height="46" Margin="0,0,10,0" Click="RetryButton_Click" Background="#1F6BFF" Foreground="White" BorderThickness="0" FontWeight="SemiBold">Continue after close</Button>
                    <Button Name="SkipButton" Width="106" Height="46" Margin="0,0,10,0" Click="SkipButton_Click" Background="#EEF2F7" Foreground="#0F172A" BorderThickness="0" FontWeight="SemiBold">Skip app</Button>
                    <Button Name="CancelButtonEx" Width="106" Height="46" Click="CancelButtonEx_Click" Background="#EEF2F7" Foreground="#0F172A" BorderThickness="0" FontWeight="SemiBold">Cancel job</Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
